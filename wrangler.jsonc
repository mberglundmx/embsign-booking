{
  "name": "brf-booking-api",
  "main": "cloudflare/worker/src/index.js",
  "compatibility_date": "2026-03-05",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "brf-booking-d1",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "cloudflare/worker/migrations"
    }
  ],
  "vars": {
    "PUBLIC_API_BASE": "/api",
    "ROOT_DOMAIN": "bokningsportal.app",
    "DEV_CAPTCHA_BYPASS": "true",
    "DEV_EMAIL_INLINE_RESPONSE": "true"
  }
}
